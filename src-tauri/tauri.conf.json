{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Haruspex",
  "version": "0.1.51",
  "identifier": "com.haruspex.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Haruspex",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https: http:; media-src 'self' blob: data:; font-src 'self' data: https:; connect-src 'self' ipc: http://ipc.localhost http: https: ws: wss:; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'none'",
      "dangerousDisableAssetCspModification": [
        "script-src",
        "style-src"
      ],
      "headers": {
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Embedder-Policy": "credentialless"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/llama-server",
      "binaries/whisper-server",
      "binaries/koko",
      "binaries/ruff"
    ],
    "resources": [
      "binaries/libs/*",
      "binaries/espeak-ng-data/*",
      "binaries/espeak-ng-data/lang/*",
      "binaries/espeak-ng-data/lang/*/*",
      "resources/shell-integration/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
