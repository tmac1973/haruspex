{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Haruspex",
  "version": "0.1.10",
  "identifier": "com.haruspex.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Haruspex",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/llama-server",
      "binaries/whisper-server",
      "binaries/koko"
    ],
    "resources": [
      "binaries/libs/*",
      "binaries/espeak-ng-data/*",
      "binaries/espeak-ng-data/lang/*",
      "binaries/espeak-ng-data/lang/*/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
