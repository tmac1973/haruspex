{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/llama-server",
          "sidecar": true
        },
        {
          "name": "binaries/whisper-server",
          "sidecar": true
        },
        {
          "name": "binaries/koko",
          "sidecar": true
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-open",
    "dialog:allow-open"
  ]
}
