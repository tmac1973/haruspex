{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/llama-server",
          "sidecar": true
        },
        {
          "name": "binaries/whisper-server",
          "sidecar": true
        },
        {
          "name": "binaries/koko",
          "sidecar": true
        },
        {
          "name": "binaries/ruff",
          "sidecar": true,
          "args": [
            "check",
            "--output-format=json",
            "--exit-zero",
            "--isolated",
            "--select=E9,F",
            { "validator": "\\S+" }
          ]
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/ruff",
          "sidecar": true,
          "args": [
            "check",
            "--output-format=json",
            "--exit-zero",
            "--isolated",
            "--select=E9,F",
            { "validator": "\\S+" }
          ]
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
